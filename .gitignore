## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Mono
mono_crash.*

# Build folders
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
publish/

# Visual Studio / Rider / JetBrains
.vs/
.idea/
*.sln.iml
*.DotSettings.user

# Generated files
Generated\ Files/
Generated_Code/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
BenchmarkDotNet.Artifacts/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Logs
*.log
*.tlog

# Database
*.mdf
*.ldf
*.ndf

# Coverage
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# Node.js / Frontend
node_modules/
dist/
.vite/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Local history
.history/
.localhistory/
.vshistory/

# Python
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.temp
*~
~$*

# npm/yarn/pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*